<% layout("layouts/boilerplate") %>

<div class="page-enter" style="max-width:780px; margin:2.5rem auto; padding:0 1rem 4rem;">

  <h3 style="margin-bottom:.5rem;">About WanderStay</h3>
  <p style="color:var(--grey-text); font-size:.88rem; margin-bottom:2rem;">Our story</p>

  <div style="background:var(--sand); border-radius:var(--radius-md); padding:2rem; border:1.5px solid var(--mist); line-height:1.85; font-size:.94rem; color:#444; margin-bottom:1.5rem;">
    <h5 style="margin-bottom:.75rem;">Who We Are</h5>
    <p style="margin-bottom:1.25rem;">WanderStay is a community-driven platform that connects travellers with unique homes and experiences around the world. We believe every journey deserves a place that feels like home — warm, personal, and memorable.</p>

    <h5 style="margin-bottom:.75rem;">Our Mission</h5>
    <p style="margin-bottom:1.25rem;">We exist to make travel more human. Our mission is to help anyone find a meaningful place to stay — whether it's a cozy mountain cabin, a seaside villa, or a vibrant city apartment — while empowering hosts to share their spaces and stories.</p>

    <h5 style="margin-bottom:.75rem;">Why WanderStay?</h5>
    <p style="margin-bottom:1.25rem;">Unlike big platforms, WanderStay is built on trust and community. Every listing is reviewed, every host is verified, and every guest is valued. We're not just a booking platform — we're a travel community.</p>

    <h5 style="margin-bottom:.75rem;">Built in India, for the World</h5>
    <p style="margin-bottom:0;">WanderStay was founded in Mumbai with a simple idea — that the best travel experiences come from staying with real people in real homes. Today, we have listings across 120+ countries and counting.</p>
  </div>

  <div style="display:flex; gap:1.5rem; flex-wrap:wrap;">
    <div style="flex:1; min-width:160px; background:var(--white); border:1.5px solid var(--mist); border-radius:var(--radius-md); padding:1.5rem; text-align:center;">
      <div style="font-family:'Playfair Display',serif; font-size:2rem; font-weight:700; color:var(--primary);">120+</div>
      <div style="font-size:.82rem; color:var(--grey-text); margin-top:4px;">Countries</div>
    </div>
    <div style="flex:1; min-width:160px; background:var(--white); border:1.5px solid var(--mist); border-radius:var(--radius-md); padding:1.5rem; text-align:center;">
      <div style="font-family:'Playfair Display',serif; font-size:2rem; font-weight:700; color:var(--primary);">4.9★</div>
      <div style="font-size:.82rem; color:var(--grey-text); margin-top:4px;">Avg. Rating</div>
    </div>
    <div style="flex:1; min-width:160px; background:var(--white); border:1.5px solid var(--mist); border-radius:var(--radius-md); padding:1.5rem; text-align:center;">
      <div style="font-family:'Playfair Display',serif; font-size:2rem; font-weight:700; color:var(--primary);">10K+</div>
      <div style="font-size:.82rem; color:var(--grey-text); margin-top:4px;">Happy Guests</div>
    </div>
  </div>

  <a href="/listings" style="display:inline-block; margin-top:1.75rem; color:var(--primary); font-weight:600; font-size:.9rem;">&larr; Back to Listings</a>
</div>
