<% layout("layouts/boilerplate") %>

<div class="form-page page-enter">
  <h3>Create a New Listing</h3>

  <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">

    <div class="mb-3">
      <label class="form-label">Title</label>
      <input name="listing[title]" type="text" class="form-control" placeholder="Give your listing a catchy title" required />
      <div class="valid-feedback">Looks good!</div>
      <div class="invalid-feedback">Title is required.</div>
    </div>

    <div class="mb-3">
      <label class="form-label">Description</label>
      <textarea name="listing[description]" class="form-control" rows="4" placeholder="Describe what makes this place special..." required></textarea>
      <div class="invalid-feedback">Please enter a description.</div>
    </div>

    <div class="mb-3">
      <label class="form-label">Listing Image</label>
      <input name="listing[image]" type="file" class="form-control" required />
    </div>

    <div class="row">
      <div class="col-md-4 mb-3">
        <label class="form-label">Price per night (&#8377;)</label>
        <input name="listing[price]" type="number" class="form-control" placeholder="1200" required />
        <div class="invalid-feedback">Enter a valid price.</div>
      </div>
      <div class="col-md-8 mb-3">
        <label class="form-label">Country</label>
        <input name="listing[country]" type="text" class="form-control" placeholder="India" required />
        <div class="invalid-feedback">Country is required.</div>
      </div>
    </div>

    <div class="mb-4">
      <label class="form-label">Location</label>
      <input name="listing[location]" type="text" class="form-control" placeholder="Jaipur, Rajasthan" required />
      <div class="invalid-feedback">Enter a valid location.</div>
    </div>

    <button type="submit" class="btn-submit">Add Listing</button>

  </form>
</div>
